BUILD_DIR := build
KERNEL_DIR := kernel
RUNTIME_DIR := kernel/runtime
LABS_DIR := kernel/labs
USER_DIR := user
TOOLS_DIR := tools

CC := riscv64-unknown-elf-gcc
LD := riscv64-unknown-elf-ld
OBJCOPY := riscv64-unknown-elf-objcopy

CFLAGS := -march=rv32imac_zicsr -mabi=ilp32 -ffreestanding -nostdlib -nostdinc -Wall -Wextra -Werror -fno-pic -fno-pie -fno-stack-protector
LDFLAGS := -m elf32lriscv

KERNEL_OBJS := \
	$(BUILD_DIR)/kernel_entry_riscv.o \
	$(BUILD_DIR)/trap_riscv.o \
	$(BUILD_DIR)/trap.o \
	$(BUILD_DIR)/kernel.o \
	$(BUILD_DIR)/runtime_state.o \
	$(BUILD_DIR)/lab1.o \
	$(BUILD_DIR)/lab2.o \
	$(BUILD_DIR)/lab3.o \
	$(BUILD_DIR)/lab4.o \
	$(BUILD_DIR)/lab5.o \
	$(BUILD_DIR)/lab6.o \
	$(BUILD_DIR)/console.o \
	$(BUILD_DIR)/memory.o \
	$(BUILD_DIR)/elf_loader.o

.PHONY: all clean run

all: $(BUILD_DIR)/kernel.elf

clean:
	chmod -R u+w $(BUILD_DIR) 2>/dev/null || true
	rm -rf $(BUILD_DIR)

run: $(BUILD_DIR)/kernel.elf
	qemu-system-riscv32 -machine virt -nographic -bios none -kernel $(BUILD_DIR)/kernel.elf

$(BUILD_DIR):
	mkdir -p $(BUILD_DIR)

$(BUILD_DIR)/kernel_entry_riscv.o: $(KERNEL_DIR)/kernel_entry_riscv.S | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/trap_riscv.o: $(KERNEL_DIR)/trap_riscv.S | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/trap.o: $(KERNEL_DIR)/trap.c $(KERNEL_DIR)/kernel.h | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/kernel.o: $(KERNEL_DIR)/kernel.c $(KERNEL_DIR)/kernel.h | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/runtime_state.o: $(RUNTIME_DIR)/runtime_state.c $(KERNEL_DIR)/kernel.h | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/lab1.o: $(LABS_DIR)/lab1/lab1.c $(KERNEL_DIR)/kernel.h | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/lab2.o: $(LABS_DIR)/lab2/lab2.c $(KERNEL_DIR)/kernel.h | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/lab3.o: $(LABS_DIR)/lab3/lab3.c $(KERNEL_DIR)/kernel.h | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/lab4.o: $(LABS_DIR)/lab4/lab4.c $(KERNEL_DIR)/kernel.h | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/lab5.o: $(LABS_DIR)/lab5/lab5.c $(KERNEL_DIR)/kernel.h | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/lab6.o: $(LABS_DIR)/lab6/lab6.c $(KERNEL_DIR)/kernel.h | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/console.o: $(KERNEL_DIR)/console.c $(KERNEL_DIR)/kernel.h | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/memory.o: $(KERNEL_DIR)/memory.c $(KERNEL_DIR)/kernel.h | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/elf_loader.o: $(KERNEL_DIR)/elf_loader.c $(KERNEL_DIR)/kernel.h | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/lab4_task_a_riscv.o: $(USER_DIR)/lab4_task_a_riscv.S | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/lab4_task_b_riscv.o: $(USER_DIR)/lab4_task_b_riscv.S | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/lab5_task_a_riscv.o: $(USER_DIR)/lab5_task_a_riscv.S | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/lab5_task_b_riscv.o: $(USER_DIR)/lab5_task_b_riscv.S | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/lab2_user_riscv.o: $(USER_DIR)/lab2_user_riscv.S | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/lab3_user_riscv.o: $(USER_DIR)/lab3_user_riscv.S | $(BUILD_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

$(BUILD_DIR)/lab2_user.elf: $(BUILD_DIR)/lab2_user_riscv.o $(USER_DIR)/user_riscv.ld
	$(LD) $(LDFLAGS) -T $(USER_DIR)/user_riscv.ld -o $@ $(BUILD_DIR)/lab2_user_riscv.o

$(BUILD_DIR)/lab3_user.elf: $(BUILD_DIR)/lab3_user_riscv.o $(USER_DIR)/user_riscv.ld
	$(LD) $(LDFLAGS) -T $(USER_DIR)/user_riscv.ld -o $@ $(BUILD_DIR)/lab3_user_riscv.o

$(BUILD_DIR)/lab4_task_a.elf: $(BUILD_DIR)/lab4_task_a_riscv.o $(USER_DIR)/user_riscv.ld
	$(LD) $(LDFLAGS) -T $(USER_DIR)/user_riscv.ld -o $@ $(BUILD_DIR)/lab4_task_a_riscv.o

$(BUILD_DIR)/lab4_task_b.elf: $(BUILD_DIR)/lab4_task_b_riscv.o $(USER_DIR)/user_riscv.ld
	$(LD) $(LDFLAGS) -T $(USER_DIR)/user_riscv.ld -o $@ $(BUILD_DIR)/lab4_task_b_riscv.o

$(BUILD_DIR)/lab5_task_a.elf: $(BUILD_DIR)/lab5_task_a_riscv.o $(USER_DIR)/user_riscv.ld
	$(LD) $(LDFLAGS) -T $(USER_DIR)/user_riscv.ld -o $@ $(BUILD_DIR)/lab5_task_a_riscv.o

$(BUILD_DIR)/lab5_task_b.elf: $(BUILD_DIR)/lab5_task_b_riscv.o $(USER_DIR)/user_riscv.ld
	$(LD) $(LDFLAGS) -T $(USER_DIR)/user_riscv.ld -o $@ $(BUILD_DIR)/lab5_task_b_riscv.o

$(BUILD_DIR)/lab2_user_program.o: $(BUILD_DIR)/lab2_user.elf
	$(LD) -m elf32lriscv -r -b binary $< -o $@

$(BUILD_DIR)/lab3_user_program.o: $(BUILD_DIR)/lab3_user.elf
	$(LD) -m elf32lriscv -r -b binary $< -o $@

$(BUILD_DIR)/lab4_task_a_program.o: $(BUILD_DIR)/lab4_task_a.elf
	$(LD) -m elf32lriscv -r -b binary $< -o $@

$(BUILD_DIR)/lab4_task_b_program.o: $(BUILD_DIR)/lab4_task_b.elf
	$(LD) -m elf32lriscv -r -b binary $< -o $@

$(BUILD_DIR)/lab5_task_a_program.o: $(BUILD_DIR)/lab5_task_a.elf
	$(LD) -m elf32lriscv -r -b binary $< -o $@

$(BUILD_DIR)/lab5_task_b_program.o: $(BUILD_DIR)/lab5_task_b.elf
	$(LD) -m elf32lriscv -r -b binary $< -o $@

$(BUILD_DIR)/disk.img: $(BUILD_DIR)/lab2_user.elf $(BUILD_DIR)/lab3_user.elf $(BUILD_DIR)/lab4_task_a.elf $(BUILD_DIR)/lab4_task_b.elf $(BUILD_DIR)/lab5_task_a.elf $(BUILD_DIR)/lab5_task_b.elf $(TOOLS_DIR)/make_fat32_image.py | $(BUILD_DIR)
	python3 $(TOOLS_DIR)/make_fat32_image.py $@

$(BUILD_DIR)/disk_program.o: $(BUILD_DIR)/disk.img
	$(LD) -m elf32lriscv -r -b binary $< -o $@

$(BUILD_DIR)/kernel.elf: $(KERNEL_OBJS) $(BUILD_DIR)/lab2_user_program.o $(BUILD_DIR)/lab3_user_program.o $(BUILD_DIR)/lab4_task_a_program.o $(BUILD_DIR)/lab4_task_b_program.o $(BUILD_DIR)/lab5_task_a_program.o $(BUILD_DIR)/lab5_task_b_program.o $(BUILD_DIR)/disk_program.o $(KERNEL_DIR)/linker.ld
	$(LD) $(LDFLAGS) -T $(KERNEL_DIR)/linker.ld -o $@ $(KERNEL_OBJS) $(BUILD_DIR)/lab2_user_program.o $(BUILD_DIR)/lab3_user_program.o $(BUILD_DIR)/lab4_task_a_program.o $(BUILD_DIR)/lab4_task_b_program.o $(BUILD_DIR)/lab5_task_a_program.o $(BUILD_DIR)/lab5_task_b_program.o $(BUILD_DIR)/disk_program.o
